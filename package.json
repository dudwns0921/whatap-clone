{
  "name": "@elio/root",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "npm run build-storybook && npm run copy-storybook && turbo run build",
    "build:dashboard": "turbo run build --filter=@elio/dashboard",
    "copy-storybook": "node -e \"const fs=require('fs');fs.mkdirSync('apps/dashboard/public',{recursive:true});fs.rmSync('apps/dashboard/public/storybook',{recursive:true,force:true});fs.cpSync('storybook-static','apps/dashboard/public/storybook',{recursive:true});\"",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "3.8.3",
    "storybook": "^8.6.18",
    "turbo": "^2.9.16",
    "typescript-eslint": "^8.60.1"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18"
  }
}
